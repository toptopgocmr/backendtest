APP_NAME="ImmoStay"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Africa/Brazzaville
APP_LOCALE=fr

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tholadbd
DB_USERNAME=root
DB_PASSWORD=

CACHE_DRIVER=file
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@immostay.tholad.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── MTN Mobile Money ───────────────────────────────────
MTN_API_URL=https://sandbox.momodeveloper.mtn.com
MTN_ENVIRONMENT=sandbox
MTN_SUBSCRIPTION_KEY=your_subscription_key_here
MTN_API_USER=your_api_user_uuid_here
MTN_API_KEY=your_api_key_here
MTN_CALLBACK_URL="${APP_URL}/api/v1/payments/mtn/callback"

# ─── Airtel Money ────────────────────────────────────────
AIRTEL_API_URL=https://openapiuat.airtel.africa
AIRTEL_CLIENT_ID=your_client_id_here
AIRTEL_CLIENT_SECRET=your_client_secret_here
AIRTEL_CALLBACK_URL="${APP_URL}/api/v1/payments/airtel/callback"
